rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction helper pour vérifier si l'utilisateur est authentifié
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Fonction helper pour récupérer les données de l'utilisateur
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Fonction helper pour vérifier si l'utilisateur est un manager
    function isManager() {
      return isSignedIn() && getUserData().role == 'manager';
    }
    
    // Fonction helper pour vérifier si l'utilisateur est un développeur
    function isDeveloper() {
      return isSignedIn() && getUserData().role == 'developer';
    }
    
    // Fonction helper pour vérifier si l'utilisateur est un client
    function isClient() {
      return isSignedIn() && getUserData().role == 'client';
    }
    
    // Rules pour la collection users
    match /users/{userId} {
      // Tout utilisateur authentifié peut lire les profils (noms, photos) pour les mentions et l'affichage
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])) ||
        isManager()
      );
      allow delete: if isManager();
    }
    
    // Coffre fort pour les mots de passe temporaires lors de l'ajout par un Manager
    match /temporaryPasswords/{userId} {
      allow read: if isManager() || request.auth.token.email == 'yves@paniscope.fr' || request.auth.uid == userId;
      allow write: if isManager() || request.auth.token.email == 'yves@paniscope.fr' || request.auth.uid == userId;
    }
    
    // Ajout d'une règle pour la génération des ID de tickets incrémentaux
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
    
    // Rules pour la collection tickets
    match /tickets/{ticketId} {
      // Lecture : clients voient leurs tickets, staff voit tout
      allow read: if isSignedIn() && (
        (request.auth.uid == resource.data.clientUid) ||
        (getUserData().companyDomain != null && getUserData().companyDomain == resource.data.companyDomain) ||
        isManager() ||
        isDeveloper()
      );
      
      // Création : Autoriser la création avec les nouveaux champs
      allow create: if isSignedIn() && (
        isManager() ||
        request.resource.data.clientUid == request.auth.uid
      );
      
      // Mise à jour :
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.clientUid) ||
        (getUserData().companyDomain != null && getUserData().companyDomain == resource.data.companyDomain) ||
        isManager() ||
        isDeveloper()
      );
      
      allow delete: if isManager();
    }

    // Rules pour la collection companies
    match /companies/{domain} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
  }
}
